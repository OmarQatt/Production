// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  CLIENT
  FREELANCER
  COMPANY
  EMPLOYEE
  ADMIN
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String
  role        UserRole @default(CLIENT)
  photoURL    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listings    Location[]
  equipment   Equipment[]
  talent      Talent?
  bookings    Booking[]
  reviews     Review[]
  favorites   Favorite[]
  messagesSent     Message[] @relation("SentMessages")
  messagesReceived Message[] @relation("ReceivedMessages")
}

model Location {
  id          String    @id @default(uuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  name        String
  description String
  type        String
  city        String
  address     String    // Only visible to admin/employees/owner
  pricePerDay Int
  photos      String    // Stored as JSON string or comma-separated for SQLite
  amenities   String?   // JSON string of amenities (e.g. WiFi, Parking, Power)
  status      String    @default("PENDING") // PENDING, ACTIVE, INACTIVE
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bookings    Booking[]
  reviews     Review[]
}

model Equipment {
  id          String    @id @default(uuid())
  companyId   String
  company     User      @relation(fields: [companyId], references: [id])
  name        String
  description String
  type        String    @default("CAMERA") // CAMERA, LIGHTING, AUDIO, GRIP
  pricePerDay Int
  photos      String    // Stored as JSON string
  status      String    @default("AVAILABLE") // AVAILABLE, RENTED, MAINTENANCE
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bookings    Booking[]
  reviews     Review[]
}

model Talent {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  type        String   // MODEL, CREW
  experience  String
  gender      String
  age         Int
  skinTone    String?
  height      Int?
  weight      Int?
  city        String
  positions   String?  // JSON string
  status      String   @default("AVAILABLE") // AVAILABLE, BUSY
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     Review[]
}

model Booking {
  id          String   @id @default(uuid())
  clientId    String
  client      User     @relation(fields: [clientId], references: [id])
  serviceId   String
  serviceType String   // LOCATION, EQUIPMENT, TALENT
  startDate   DateTime
  endDate     DateTime
  totalPrice  Int
  status      String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // These are optional relations for easier querying depending on type
  location    Location? @relation(fields: [serviceId], references: [id])
  equipment   Equipment? @relation(fields: [serviceId], references: [id])
}

model Review {
  id          String    @id @default(uuid())
  targetId    String
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  authorName  String
  rating      Int
  comment     String
  createdAt   DateTime  @default(now())

  location    Location? @relation(fields: [targetId], references: [id])
  equipment   Equipment? @relation(fields: [targetId], references: [id])
  talent      Talent?   @relation(fields: [targetId], references: [id])
}

model Favorite {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  targetId    String   // ID of location, equipment, talent
  targetType  String   // LOCATION, EQUIPMENT, TALENT
  createdAt   DateTime @default(now())

  @@unique([userId, targetId])
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  targetId    String   // Service ID interested in
  content     String
  priceOffer  Int?     // Optional negotiation price
  createdAt   DateTime @default(now())
}
